# Service identity
AUMOS_SERVICE_NAME=aumos-federated-learning
AUMOS_SERVICE_VERSION=0.1.0
AUMOS_ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_federated_learning
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=aumos-federated-learning

# Redis
REDIS_URL=redis://localhost:6379/0

# Privacy Engine
PRIVACY_ENGINE_URL=http://localhost:8001

# Model Registry
MODEL_REGISTRY_URL=http://localhost:8002

# Federated Learning Settings
FL_DEFAULT_STRATEGY=fedavg
FL_MIN_PARTICIPANTS=2
FL_MAX_ROUNDS=100
FL_ROUND_TIMEOUT_SECONDS=3600
FL_MODEL_STORAGE_BACKEND=local
FL_MODEL_STORAGE_PATH=/tmp/aumos_fl_models

# Differential Privacy defaults
FL_DEFAULT_DP_EPSILON=1.0
FL_DEFAULT_DP_DELTA=1e-5
FL_DP_NOISE_MULTIPLIER=1.1
FL_DP_MAX_GRAD_NORM=1.0

# Secure Aggregation
FL_SECURE_AGG_ENABLED=true
FL_SECURE_AGG_THRESHOLD=0.6

# Flower server (gRPC)
FLOWER_SERVER_ADDRESS=0.0.0.0:9091
FLOWER_SSL_ENABLED=false
FLOWER_SSL_CA_CERT=
FLOWER_SSL_SERVER_CERT=
FLOWER_SSL_SERVER_KEY=

# Auth / JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
